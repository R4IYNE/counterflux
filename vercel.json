{
  "rewrites": [
    { "source": "/api/edhrec/:path*", "destination": "/api/edhrec?path=:path*" },
    { "source": "/api/spellbook/:path*", "destination": "/api/spellbook?path=:path*" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
